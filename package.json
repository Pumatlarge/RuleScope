{
  "name": "company-regulations-search-engine",
  "version": "1.0.0",
  "description": "企业规章制度检索管理系统",
  "main": "main.js",
  "scripts": {
    "start": "node server-filemanager.js",
    "electron": "electron .",
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "nodemon server-filemanager.js",
    "client:dev": "cd client && npm start",
    "build": "cd client && npm run build",
    "dist": "electron-builder",
    "build-portable": "npm run build && electron-builder -w portable",
    "install:all": "npm install && cd client && npm install"
  },
  "keywords": [
    "企业规章制度",
    "文档管理",
    "检索系统",
    "版本管理",
    "文档对比"
  ],
  "author": "Company Regulations Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "diff": "^5.2.2",
    "docx": "^8.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.5.0",
    "builder-util-runtime": "^9.2.4",
    "concurrently": "^8.2.0",
    "electron": "^34.5.8",
    "electron-builder": "^24.13.3",
    "electron-packager": "^17.1.2",
    "eslint": "^8.47.0",
    "jest": "^29.6.2",
    "nodemon": "^3.0.1",
    "typescript": "^5.1.6"
  },
  "build": {
    "appId": "com.pylontech.regs",
    "productName": "公司规章检索分析系统",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "main.js",
      "server-filemanager.js",
      "db.json",
      "highlights.json",
      "uploads/**/*",
      "client/build/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "client/public/favicon.ico",
      "forceCodeSigning": false
    }
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
